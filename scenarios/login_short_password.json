{
  "name": "login_short_password",
  "description": "Verify that a password shorter than 6 characters triggers a validation error.",
  "priority": "medium",
  "steps": [
    {
      "action": "goto",
      "value": "https://ckan-test.go-te.co"
    },
    {
      "action": "type",
      "selector": "input[type=\"password\"]",
      "value": "12345"
    },
    {
      "action": "click",
      "selector": "button[type=\"submit\"]"
    },
    {
      "action": "assert_text",
      "selector": "input[type=\"password\"] + .validation-error",
      "value": "Password must be at least 6 characters"
    }
  ],
  "url": "https://ckan-test.go-te.co"
}