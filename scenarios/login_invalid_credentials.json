{
  "name": "login_invalid_credentials",
  "description": "Verify that an error message is displayed when incorrect credentials are entered.",
  "priority": "high",
  "steps": [
    {
      "action": "goto",
      "value": "https://ckan-test.go-te.co"
    },
    {
      "action": "type",
      "selector": "input[name=\"login\"]",
      "value": "invaliduser"
    },
    {
      "action": "type",
      "selector": "input[type=\"password\"]",
      "value": "wrongpass"
    },
    {
      "action": "click",
      "selector": "button[type=\"submit\"]"
    },
    {
      "action": "assert_text",
      "selector": "div.error-message",
      "value": "Invalid credentials"
    }
  ],
  "url": "https://ckan-test.go-te.co"
}